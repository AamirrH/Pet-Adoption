<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background">

    <TextView android:id="@+id/tvAppsTitle" android:layout_width="0dp" android:layout_height="wrap_content"
        android:padding="20dp" android:text="@string/my_applications" android:textColor="@color/text_primary"
        android:textSize="24sp" android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ScrollView android:id="@+id/scrollApps" android:layout_width="0dp" android:layout_height="0dp"
        android:layout_marginTop="4dp" android:paddingStart="12dp" android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvAppsTitle">
        <LinearLayout android:id="@+id/appsList" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="16dp"/>
    </ScrollView>

    <TextView android:id="@+id/tvAppsEmpty" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:gravity="center" android:text="@string/no_applications" android:textColor="@color/text_hint"
        android:textSize="16sp" android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/tvAppsTitle"/>
</androidx.constraintlayout.widget.ConstraintLayout>
