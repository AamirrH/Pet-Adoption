<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:id="@+id/main"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background">

    <LinearLayout android:id="@+id/header" android:layout_width="0dp" android:layout_height="wrap_content"
        android:background="@color/primary" android:orientation="vertical" android:padding="20dp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/welcome_back" android:textColor="@color/primary_light" android:textSize="14sp"/>
        <TextView android:id="@+id/tvUserName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="User" android:textColor="@color/white"
            android:textSize="24sp" android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/statsBar" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="-12dp" android:orientation="horizontal" android:paddingStart="12dp"
        android:paddingEnd="12dp" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/header">

        <RelativeLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/card_bg"
            android:elevation="4dp" android:padding="14dp">
            <TextView android:id="@+id/labelAvail" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="🐾 Available"
                android:textColor="@color/primary" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvPetCount" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_below="@id/labelAvail"
                android:layout_marginTop="4dp" android:text="0" android:textColor="@color/primary"
                android:textSize="22sp" android:textStyle="bold"/>
        </RelativeLayout>

        <RelativeLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_margin="4dp" android:background="@drawable/card_bg"
            android:elevation="4dp" android:padding="14dp">
            <TextView android:id="@+id/labelApps" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="📋 My Apps"
                android:textColor="@color/accent" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvAppCount" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:layout_below="@id/labelApps"
                android:layout_marginTop="4dp" android:text="0" android:textColor="@color/accent"
                android:textSize="22sp" android:textStyle="bold"/>
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/filterRow" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
        android:background="@drawable/card_bg" android:elevation="2dp" android:gravity="center_vertical"
        android:orientation="horizontal" android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statsBar">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/filter_label" android:textColor="@color/text_primary"
            android:textSize="14sp" android:textStyle="bold"/>
        <Spinner android:id="@+id/spinnerFilter" android:layout_width="0dp" android:layout_height="36dp"
            android:layout_weight="1" android:entries="@array/filter_types"/>
    </LinearLayout>

    <ScrollView android:id="@+id/scrollPets" android:layout_width="0dp" android:layout_height="0dp"
        android:layout_marginTop="8dp" android:paddingStart="12dp" android:paddingEnd="12dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/filterRow">
        <LinearLayout android:id="@+id/petList" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="16dp"/>
    </ScrollView>

    <TextView android:id="@+id/tvEmpty" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:gravity="center" android:text="@string/no_pets" android:textColor="@color/text_hint"
        android:textSize="16sp" android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/filterRow"/>

    <!-- Bottom Nav with Admin Panel -->
    <LinearLayout android:id="@+id/bottomNav" android:layout_width="0dp" android:layout_height="60dp"
        android:background="@color/card_white" android:elevation="12dp" android:gravity="center_vertical"
        android:orientation="horizontal" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent">
        <TextView android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="@string/nav_home"
            android:textColor="@color/primary" android:textSize="11sp" android:textStyle="bold"/>
        <TextView android:id="@+id/navApps" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="@string/nav_apps"
            android:textColor="@color/text_secondary" android:textSize="11sp"/>
        <TextView android:id="@+id/navQuiz" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="@string/nav_quiz"
            android:textColor="@color/text_secondary" android:textSize="11sp"/>
        <TextView android:id="@+id/navAdmin" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="🛡️\nAdmin"
            android:textColor="@color/text_secondary" android:textSize="11sp"/>
        <TextView android:id="@+id/navSettings" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="@string/nav_settings"
            android:textColor="@color/text_secondary" android:textSize="11sp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>