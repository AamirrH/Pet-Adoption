<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@drawable/card_bg" android:elevation="3dp" android:gravity="center_vertical"
    android:layout_marginBottom="8dp" android:layout_marginStart="4dp" android:layout_marginEnd="4dp"
    android:orientation="horizontal" android:padding="14dp">
 
    <TextView android:id="@+id/tvPetEmoji" android:layout_width="50dp" android:layout_height="50dp"
        android:gravity="center" android:textSize="28sp" android:background="@drawable/card_bg"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvPetName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/text_primary"
            android:textSize="16sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvPetBreed" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <TextView android:id="@+id/tvPetMeta" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginTop="2dp"
            android:textColor="@color/text_hint" android:textSize="11sp"/>
    </LinearLayout>

    <TextView android:id="@+id/tvPetStatus" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:background="@drawable/card_bg"
        android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="4dp"
        android:paddingBottom="4dp" android:text="Available" android:textSize="11sp" android:textStyle="bold"/>
</LinearLayout>
